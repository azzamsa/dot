#!/usr/bin/env nu

#
# Clean system
#

def task-kondo []: any -> string {
    print "🧽 Cleaning dependencies and build artifacts"
    kondo $env.HOME --older 2w --ignored-dirs ($env.HOME | path join .local/bin/node) --all
}

def task-system []: any -> string {
    print "🧽 Cleaning package manager cache"
    sudo dnf autoremove
}

def task-flatpak []: any -> string {
    print "🧽 Cleaning unused flatpak packages"
    flatpak uninstall --unused
}

def task-cargo []: any -> string {
    print "🧽 Cleaning cargo cache"
    cargo cache --autoclean
}

def task-container []: any -> string {
    print "🧽 Cleaning container cache"
    podman system prune
}

# def task-dirs [] {
#     print "🧽 Cleaning ~/Downloads, ~/Pictures/Screenshots dirs"
#     let dirs = [
#         ($env.HOME | path join "Downloads")
#         ($env.HOME | path join "Pictures/Screenshots")
#     ]
