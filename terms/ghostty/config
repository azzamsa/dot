# I wanted to have zero-config, but block cursor signals my brain that I am in Visual mode.
# as I am using modal editor all the time.
cursor-style = bar
# The default is to thin
adjust-cursor-thickness = 200%

# Otherwise it will start in small window.
# I always put all apps in maximized mode.
maximize = true

# Fonts
font-family = {{ command_output "rfont" }}
font-size = {{ terminal_font_size }}

# UI
window-padding-x = 10
window-padding-y = 10

custom-shader-animation = true
# https://github.com/sahaj-b/ghostty-cursor-shaders
custom-shader = "shaders/cursor_warp.glsl"

#
# Keybindings

# Clipboard
# Maintain consistency with my other apps: nvim, emacs
# Some app doesn't accept `copy` key,
# and pressing `Ctrl-Shift-v` is cumbersome in my keyboard.
keybind = alt+w=copy_to_clipboard
keybind = ctrl+y=paste_from_clipboard

# Panes
keybind = ctrl+shift+w=close_surface
keybind = ctrl+shift+h=new_split:right
keybind = ctrl+shift+v=unbind
keybind = ctrl+shift+v=new_split:down

# Theme
# See https://github.com/mbadolato/iTerm2-Color-Schemes
theme = {{ theme }}
