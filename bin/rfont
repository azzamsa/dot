#!/usr/bin/env -S nu --stdin

#
# Random Font
#

def "main current" []: nothing -> list<string> {
    ghostty +show-config | find font-family
}

def main []: nothing -> string {
    let fonts_file = ("~/.config/meta/fonts.toml" | path expand)
    let fonts = (open $fonts_file | get font)
    if ($fonts | is-empty) {
        error make {msg: $"No fonts in ($fonts_file)"}
    }
    $fonts | shuffle | first | get name
}
