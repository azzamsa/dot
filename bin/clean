#!/usr/bin/env nu

#
# Clean system
#

def task-kondo []: nothing -> nothing {
    kondo $env.HOME --older 2w --ignored-dirs ($env.HOME | path join .local/bin/node) --all
}

def task-system []: nothing -> nothing {
    sudo dnf autoremove
}

def task-flatpak []: nothing -> nothing {
    flatpak uninstall --unused
}

def task-cargo []: nothing -> nothing {
    cargo cache --autoclean
}

def task-container []: nothing -> nothing {
    podman system prune
}

def section [msg: string]: nothing -> nothing {
    print $"\n🧽 ($msg)"
}

def run-all []: nothing -> nothing {
    section "Cleaning dependencies and build artifacts"
    task-kondo

    section "Cleaning unused flatpak packages"
    task-flatpak

    section "Cleaning container cache"
    task-container

    section "Cleaning cargo cache"
    task-cargo

    section "Cleaning package manager cache"
    task-system
}


def main [
    ...tasks: string  # kondo, flatpak, container, cargo, system (default: all)
]: nothing -> nothing {
    let tasks_map = {
        kondo:     { task-kondo }
        flatpak:   { task-flatpak }
        container: { task-container }
        cargo:     { task-cargo }
        system:    { task-system }
    }

    if ($tasks | is-empty) {
        run-all
    } else {
        for task in $tasks {
            if ($tasks_map has $task) {
                do ($tasks_map | get --optional $task)
            } else {
                error make {msg: $"Unknown task: ($task)"}
            }
        }
    }

    print "\n✨ You have a new shiny machine!"
}
