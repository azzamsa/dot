{
  "buffer_font_family": "Maple Mono NF",
  "vim_mode": true,
  "helix_mode": false,
  "vim": {
    "use_system_clipboard": "always",
  },
  "languages": {
    "Rust": {
      "inlay_hints": {
        "enabled": true,
      },
    },
  },
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },
  "show_edit_predictions": true,
  "minimap": {
    "show": "auto",
  },
  "soft_wrap": "editor_width",
  "relative_line_numbers": "enabled",
  "autosave": "on_focus_change",
  "icon_theme": "Catppuccin Mocha",
  "ui_font_size": 19,
  "buffer_font_size": 24.0,
  // lsp
  "lsp_document_colors": "background",
  "theme": {
    "mode": "dark",
    "light": "Modus Operandi Tinted",
    "dark": "Tokyo Black",
  },
  "ui_font_features": {
    "calt": true,
  },
  "theme_overrides": {
    "GitHub Dark": {
      // Editor
      "editor.background": "#000000",
    },
    "Modus Vivendi": {
      // Tab
      "tab_bar.background": "#000000",
      "tab.inactive_background": "#000000",
      "tab.active_background": "#0d0e1c", // bg-main
    },
    "Modus Vivendi Tinted": {
      // Editor
      "editor.background": "#000000",
      "editor.gutter.background": "#0d0e1c", // bg-main
      "editor.active_line_number": "#ff66ff", // magenta-intense
      // Tab
      "tab_bar.background": "#000000",
      "tab.inactive_background": "#000000",
      "tab.active_background": "#0d0e1c", // bg-main
    },
  },
  "auto_install_extensions": {
    "basher": true,
    "catppuccin-icons": true,
    "color-highlight": true,
    "dockerfile": true,
    "elisp": true,
    "fish": true,
    "git-firefly": true,
    "graphql": true,
    "html": true,
    "jsonnet": true,
    "just": true,
    "make": true,
    "modus-themes": true,
    "nu": true,
    "nu-lint": true,
    "scss": true,
    "sql": true,
    "svelte": true,
    "toml": true,
    "typst": true,
    "vue": true,
  },
}
