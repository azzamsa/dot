#!/usr/bin/env -S nu --stdin

def show-clock [--width: int, row: record] {
    let now   = (date now | date to-timezone $row.tz)
    let hour  = ($now | format date %H | into int)
    let time  = ($now | format date "%I:%M %p")
    let loc_p = ($row.loc | fill --width $width)
    let color = if ($hour >= 6 and $hour < 18) {
        ansi green
    } else {
        ansi red
    }
    print $"($loc_p) : ($color)($time)(ansi reset)"
}

def main [] {
    let file      = "~/.config/meta/tz.toml" | path expand
    let locations = open $file | get locations

    let width = ($locations | get loc | each {|l| $l | str length } | math max)
    for row in $locations {
        show-clock --width $width $row
    }
}
