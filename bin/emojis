#!/usr/bin/env nu

#
# Random Emoji
#

# Get a random emoji
def main [
    category?: string  # foods, nature, animals
    --file: path       # Path to a custom emojis file
] {
    let file = if $file == null {
        "~/.config/meta/emojis.toml" | path expand
    } else {
        $file
    }
    let categories = (open $file)

    let emojis = if ($category | is-empty) {
        $categories | values | flatten
    } else {
        $categories | get --optional $category
    }

    let index = (random int 0..<($emojis | length))
    $emojis | get --optional $index
}
