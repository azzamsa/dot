#!/usr/bin/env nu
#
# Random Quote
#
# Get a random motivational quote
def main [
    --quoted   (-q)           # Wrap with quotes
    --period   (-p)           # End with dot
    --emoji    (-e)           # Prefix with emoji
    --category (-c): string   # Filter by category (e.g. islamic, general)
    --file     (-f): path     # Path to a custom quotes file
] {
    let file = ($file | default ("~/.config/meta/quotes.toml" | path expand))
    let data = (open $file)

    let quotes = if ($category | is-empty) {
        $data | values | flatten
    } else {
        $data | get --optional $category
    }

    let index = (random int 0..<($quotes | length))
    mut quote = ($quotes | get --optional $index)

    if $period { $quote = $"($quote)." }
    if $quoted { $quote = $'"($quote)"' }
    if $emoji  { $quote = $"🌿 ($quote)" }

    print $quote
}
