#!/usr/bin/env nu

def brightness-icon [level: int]: any -> string {
  if $level >= 50 { '🔆' } else { '🔅' }
}

def get-brightness []: any -> int {
  ddcutil getvcp 10
    | parse --regex "current value =\\s+(?P<val>\\d+)"
    | get --optional val.0
    | into int
}

def set-brightness [level: int]: any -> string {
  ddcutil setvcp 10 $level
}

def target-brightness []: any -> int {
  let hour = (date now | format date %H | into int)
  if $hour >= 6 and $hour < 18 { 50 } else { 35 }
}

let prev = get-brightness
let level = target-brightness
set-brightness $level
print $"(brightness-icon $prev) ($prev)% -> (brightness-icon $level) ($level)%"
