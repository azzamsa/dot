#!/usr/bin/env nu
#
# Create a release
#

# Create a release with the given tag
def main [tag: string] {
    # Check for untracked files
    let untracked = (git ls-files . --exclude-standard --others | str trim)
    if $untracked != "" {
        error make { msg: "Error: Please stash or remove the untracked files!" }
    }

    # Update the changelog
    print "Updating the changelog"
    git-cliff --config .cliff.toml --tag $tag --output CHANGELOG.md

    # Format the newly created changelog file
    just fmt

    # Write the new version to a file 'version'
    $tag | save --force version

    # Commit a release
    git add --all
    git commit --message $tag
    git show
    git tag --sign --annotate $tag --message "For details, see the CHANGELOG.md"
    git tag --verify $tag
}
