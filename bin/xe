#!/usr/bin/env -S nu --stdin

#
# Currency converter
#

def humanize_idr [n: float] {
    $n | math round | into int | into string --group-digits
}

def humanize_usd [n: float] {
    let whole = ($n | math floor | into int | into string --group-digits)
    let cents = ($n * 100 | math round | into int) mod 100
    $"($whole).($cents | fill -a right -c '0' -w 2)"
}

def fetch_rate [] {
    let api_url = "https://cdn.jsdelivr.net/npm/@fawazahmed0/currency-api@latest/v1/currencies/usd.json"
    (http get $api_url).usd.idr
}

# Convert USD to IDR
def "main to-idr" [amount: float] {
    let rate = fetch_rate
    print $"USD (humanize_usd $amount) = IDR (humanize_idr ($amount * $rate))"
}

# Convert IDR to USD
def "main to-usd" [amount: float] {
    let rate = fetch_rate
    print $"IDR (humanize_idr $amount) = USD (humanize_usd ($amount / $rate))"
}

# Currency converter: USD ↔ IDR
def main [] {
    print "Usage: xe <subcommand> <amount>"
    print "  xe to-idr <amount>   Convert USD → IDR"
    print "  xe to-usd <amount>   Convert IDR → USD"
}
