#!/usr/bin/env nu

#
# Random Name
#

# Get a random name
def main [
    category?: string  # islamic, lotr
    --file: path       # Path to a custom names file
] {
    let file = ($file | default ("~/.config/meta/names.toml" | path expand))
    let categories = (open $file)

    let names = if ($category | is-empty) {
        $categories | values | flatten
    } else {
        $categories | get --optional $category
    }

    let index = (random int 0..<($names | length))
    $names | get --optional $index
}
