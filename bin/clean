#     }
# }


def run-all []: any -> string {
    task-kondo
    task-flatpak
    task-container
    task-cargo
    task-system
}


def main [
    ...tasks: string  # kondo, flatpak, container, cargo, system (default: all)
] {
    let tasks_map = {
        kondo:     { task-kondo }
        flatpak:   { task-flatpak }
        container: { task-container }
        cargo:     { task-cargo }
        system:        { task-system }
    }

    if ($tasks | is-empty) {
        run-all
    } else {
        for task in $tasks {
            if ($tasks_map has $task) {
                do ($tasks_map | get --optional $task)
            } else {
                error make {msg: $"Unknown task: ($task)"}
            }
        }
    }

    print "\n✨ You have a new shiny machine!"
}
