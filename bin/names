#!/usr/bin/env nu

#
# Random Name
#

# Get a random name
def main [
    file?: path           # Path to a custom names file (default: ~/.config/meta/names.toml)
    --no-adj              # Skip the adjective prefix
    --sep (-s): string = "-" # Separator between adjective and noun (default: "-")
]: nothing -> string {
    let file = $file | default ("~/.config/meta/names.toml" | path expand)
    let data = open $file
    let nouns = $data.nouns
    let name = $nouns | get --optional (random int 0..<($nouns | length))
    if $no_adj {
        $name
    } else {
        let adjs = $data.adjectives
        let adj = $adjs | get --optional (random int 0..<($adjs | length))
        $"($adj)($sep)($name)"
    }
}
